# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL user. Use a strong random string.
POSTGRES_PASSWORD=changeme

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server refuses to start if these are missing.
JWT_ACCESS_SECRET=replace-with-random-64-char-hex
JWT_REFRESH_SECRET=replace-with-different-random-64-char-hex

# ── Client ────────────────────────────────────────────────────────────────────
# Port to expose the web UI on (default: 80)
APP_PORT=80

# The URL users access the app at. Must match exactly for CORS.
# Examples: http://192.168.1.100, https://newtab.yourdomain.com
CLIENT_ORIGIN=http://localhost

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set to false when running over plain HTTP (local network without TLS).
# Set to true (or omit) when behind an HTTPS reverse proxy — required for production.
COOKIE_SECURE=true

# ── Proxy / rate limiting ─────────────────────────────────────────────────────
# Number of proxy hops in front of the server, so per-IP rate limiting sees the
# real client IP. Leave UNSET for `npm run dev` (direct connection). Set to 1 for
# the local docker-compose stack (client nginx), or 2 behind a reverse proxy + nginx.
# TRUST_PROXY=2

# ── Registration ──────────────────────────────────────────────────────────────
# Set to false to close registration (existing users can still log in).
# Recommended once you have created your account(s) on a public-facing server.
REGISTRATION_ENABLED=true

# ── Console features ──────────────────────────────────────────────────────────
# Set to false to disable the ping/tracert endpoints entirely.
# Recommended if you don't use the built-in network console widget.
CONSOLE_ENABLED=true
