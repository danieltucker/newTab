generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  username      String            @unique
  email         String?           @unique
  passwordHash  String
  isAdmin       Boolean           @default(false)
  bannedAt      DateTime?
  firstName     String?
  lastName      String?
  avatar        String?
  settings      Json              @default("{}")
  totpSecret        String?
  totpPendingSecret String?
  totpEnabled       Boolean           @default(false)
  createdAt     DateTime          @default(now())
  folders       Folder[]
  bookmarks     Bookmark[]
  readingList   ReadingListItem[]
  refreshTokens RefreshToken[]
  dismissedFeedItems DismissedFeedItem[]
  readFeedItems      ReadFeedItem[]
  comments           Comment[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Folder {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  color             String
  position          Int
  feedUrls          String[]      @default([])
  feedLastCheckedAt DateTime?
  backgroundImage   String?
  bookmarks         Bookmark[]
  dismissedFeedItems DismissedFeedItem[]
  createdAt         DateTime      @default(now())

  @@index([userId])
}

// Feeds and their items are shared across all users — one fetch per feed
// regardless of how many folders/users reference it. canonicalKey normalises
// scheme/www/trailing-slash so URL permutations map to the same feed.
model Feed {
  id            String     @id @default(cuid())
  canonicalKey  String     @unique
  fetchUrl      String
  title         String     @default("")
  lastCheckedAt DateTime?
  // Conditional-GET validators from the last successful fetch. Sent back as
  // If-None-Match / If-Modified-Since so an unchanged feed answers 304 with no
  // body and no re-upsert.
  etag          String?
  lastModified  String?
  // Last time a user actually requested this feed (opened its folder, checked a
  // bookmark). The background scheduler only refreshes feeds demanded recently,
  // so feeds nobody looks at go dormant and stop costing outbound requests.
  lastRequestedAt DateTime?
  items         FeedItem[]

  @@index([lastCheckedAt])
}

model FeedItem {
  id         String    @id @default(cuid())
  feedId     String
  feed       Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  link       String
  // Canonical form of link — lets an article be found from any URL spelling,
  // the same key comments are threaded on
  linkKey    String?
  title      String
  pubDate    DateTime?
  fetchedAt  DateTime  @default(now())
  readTime   Int?
  snippet    String?
  // Full article HTML from the feed, sanitized on write. Backfills on the next
  // refresh for items stored before this column existed.
  content    String?
  imageUrl   String?
  categories String[]  @default([])
  dismissals DismissedFeedItem[]
  reads      ReadFeedItem[]

  @@unique([feedId, link])
  @@index([feedId])
  @@index([linkKey])
}

// Per-user, per-folder state on shared items (dismissed / saved-away)
model DismissedFeedItem {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  itemId    String
  item      FeedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, folderId, itemId])
  @@index([folderId, userId])
}

// Read state is per-user but NOT per-folder: an item you scrolled past in one
// folder stays read everywhere it appears.
model ReadFeedItem {
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId String
  item   FeedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  readAt DateTime @default(now())

  @@id([userId, itemId])
  @@index([userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  folderId   String?
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain     String
  name       String
  faviconUrl String
  color      String
  position      Int
  feedUrl       String?
  feedCheckedAt DateTime?
  feedLatestAt  DateTime?
  unreadCount   Int       @default(0)
  lastVisitedAt DateTime?
  // Pinned bookmarks surface in the sidebar's top pin grid. They keep their
  // folder membership — pinning is a view flag, not a move.
  pinned        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([folderId])
}

// Comments attach to an article by its canonical URL key, so the same thread
// shows whether the article lives in the reading list or the RSS feed. Threaded
// via parentId; only root comments (parentId == null) may set a title.
// isPublic comments are visible to every user; private ones only to the author.
model Comment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleKey   String    // canonical URL key — the join across reading list + feed
  articleUrl   String    // original URL, kept for reference/linking
  articleTitle String    @default("")
  parentId     String?
  parent       Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[] @relation("CommentThread")
  title        String?   // root comments only
  body         String    // sanitized HTML from the rich editor
  isPublic     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([articleKey])
  @@index([userId])
  @@index([parentId])
}

model ReadingListItem {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url      String
  title    String
  source   String
  readTime String
  tag      String
  notes    String   @default("")
  imageUrl String   @default("")
  archived Boolean  @default(false)
  savedAt  DateTime @default(now())

  @@index([userId])
}
