generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  username      String            @unique
  email         String?           @unique
  passwordHash  String
  isAdmin       Boolean           @default(false)
  bannedAt      DateTime?
  firstName     String?
  lastName      String?
  avatar        String?
  settings      Json              @default("{}")
  totpSecret        String?
  totpPendingSecret String?
  totpEnabled       Boolean           @default(false)
  createdAt     DateTime          @default(now())
  folders       Folder[]
  bookmarks     Bookmark[]
  readingList   ReadingListItem[]
  refreshTokens RefreshToken[]
  dismissedFeedItems DismissedFeedItem[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Folder {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  color             String
  position          Int
  feedUrls          String[]      @default([])
  feedLastCheckedAt DateTime?
  backgroundImage   String?
  bookmarks         Bookmark[]
  dismissedFeedItems DismissedFeedItem[]
  createdAt         DateTime      @default(now())

  @@index([userId])
}

// Feeds and their items are shared across all users — one fetch per feed
// regardless of how many folders/users reference it. canonicalKey normalises
// scheme/www/trailing-slash so URL permutations map to the same feed.
model Feed {
  id            String     @id @default(cuid())
  canonicalKey  String     @unique
  fetchUrl      String
  title         String     @default("")
  lastCheckedAt DateTime?
  items         FeedItem[]
}

model FeedItem {
  id         String    @id @default(cuid())
  feedId     String
  feed       Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  link       String
  title      String
  pubDate    DateTime?
  fetchedAt  DateTime  @default(now())
  readTime   Int?
  snippet    String?
  imageUrl   String?
  categories String[]  @default([])
  dismissals DismissedFeedItem[]

  @@unique([feedId, link])
  @@index([feedId])
}

// Per-user, per-folder state on shared items (dismissed / saved-away)
model DismissedFeedItem {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  itemId    String
  item      FeedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, folderId, itemId])
  @@index([folderId, userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  folderId   String
  folder     Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain     String
  name       String
  faviconUrl String
  color      String
  position      Int
  feedUrl       String?
  feedCheckedAt DateTime?
  feedLatestAt  DateTime?
  unreadCount   Int       @default(0)
  lastVisitedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([folderId])
}

model ReadingListItem {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url      String
  title    String
  source   String
  readTime String
  tag      String
  notes    String   @default("")
  imageUrl String   @default("")
  archived Boolean  @default(false)
  savedAt  DateTime @default(now())

  @@index([userId])
}
