# ─────────────────────────────────────────────────────────────────────────────
# Production env for TrueNAS deployment (docker-compose.truenas.yml).
# Copy to ".env" in the same directory as the compose file and fill in.
# The real .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── GHCR image source ──────────────────────────────────────────────────────────
# GitHub username/org that owns the pushed images, and the tag to run.
GHCR_OWNER=danieltucker
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────────────────────────────
# Strong random password.  Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME
# TrueNAS dataset path that will hold the Postgres data (create the dataset first).
PGDATA_HOST_PATH=/mnt/YOURPOOL/apps/newtab/pgdata

# ── JWT secrets (REQUIRED — server refuses to start in prod without them) ───────
# Generate each separately:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX

# ── HTTPS / reverse proxy ──────────────────────────────────────────────────────
# Exact public URL users visit (scheme + host, no trailing slash). Must match for CORS.
CLIENT_ORIGIN=https://newtab.yourdomain.com
# Keep true — you are serving over HTTPS. Auth cookies require this.
COOKIE_SECURE=true
# Proxy hops in front of the server so rate limiting keys on the real client IP.
# Your reverse proxy + the client nginx = 2. (Cloudflare Tunnel etc. may differ.)
TRUST_PROXY=2

# ── Host port ──────────────────────────────────────────────────────────────────
# The client (nginx) is published here; point your reverse proxy at truenas-ip:APP_PORT.
# Do NOT use 80/443 (TrueNAS web UI). 30000+ is a safe range.
APP_PORT=30080

# ── Feature flags ──────────────────────────────────────────────────────────────
# Close signups after creating your account(s).
REGISTRATION_ENABLED=true
# Console ping/tracert endpoints — keep false on an internet-facing deployment.
CONSOLE_ENABLED=false
